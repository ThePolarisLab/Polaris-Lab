# Polaris runtime profile: development, staging, or builder
POLARIS_ENV=development

# Public service metadata
POLARIS_SERVICE_NAME=Polaris Chief of Staff API
POLARIS_VERSION=0.8.0-alpha

# Founding builder organization context
POLARIS_ORGANIZATION_SLUG=mor-logistics

# Comma-separated frontend origins permitted by CORS
POLARIS_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
